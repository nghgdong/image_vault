# Sao chép file này thành .env và điền giá trị thật. KHÔNG commit .env.
# (.NET đọc config qua biến môi trường, dấu "__" = cấp lồng nhau, vd JWT__SECRET -> Jwt:Secret)

# --- MongoDB ---
MONGO__DATABASE=image_vault

# --- JWT (BẮT BUỘC) — chuỗi ngẫu nhiên >= 32 ký tự ---
JWT__SECRET=thay-bang-chuoi-ngau-nhien-toi-thieu-32-ky-tu
JWT__ISSUER=image-vault
JWT__EXPIRYHOURS=8

# --- freeimage.host (Phase 2 mới dùng thật; Phase 1 chạy stub) ---
FREEIMAGE__APIKEY=chv_xxx
FREEIMAGE__BASEURL=https://freeimage.host/api/1/upload

# --- Admin seed (BẮT BUỘC) — đổi mật khẩu ngay ---
ADMIN__USERNAME=admin
ADMIN__PASSWORD=doi-mat-khau-nay-ngay

# --- CORS — origin của frontend, phân tách bằng dấu phẩy ---
CORS__ALLOWEDORIGINS=http://localhost:3000

# --- Cổng host map ra API ---
API_PORT=8080
